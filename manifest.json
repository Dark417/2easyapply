{
    "manifest_version": 3,
    "name": "easyapply",
    "version": "1.0",
    "description": "Local MVP Chrome Extension for automating and autofilling LinkedIn Easy Apply workflows.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "*://*.linkedin.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "easyapply Configuration"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.linkedin.com/*"
            ],
            "css": [
                "ui.css"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end"
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}